# Management-cluster bootstrap inputs.

MANAGEMENT_KUBECONFIG=$HOME/.kube/config
MANAGEMENT_CONTEXT=management

ARGOCD_NAMESPACE=argocd
ARGOCD_BOOTSTRAP_KUSTOMIZE=bootstrap/argocd
ROOT_APP_MANIFEST=bootstrap/root/root.yaml
ARGOCD_BOOTSTRAP_TIMEOUT=300s

BOOTSTRAP_REPO_URL=https://github.com/litomi2026/litomi-gitops.git
BOOTSTRAP_REPO_TYPE=git
BOOTSTRAP_REPO_SECRET_NAME=github-repo-creds
BOOTSTRAP_REPO_USERNAME=git
BOOTSTRAP_REPO_TOKEN_FILE=/secure/bootstrap/github-token.txt

# Optional verify defaults.
WORKLOAD_CLUSTER_NAME=stg-01
WORKLOAD_KUBECONFIG=/secure/kubeconfigs/stg-01.yaml
WORKLOAD_CONTEXT=default
