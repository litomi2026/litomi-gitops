# Vault bootstrap and seed inputs.

WORKLOAD_KUBECONFIG=/secure/kubeconfigs/stg-01.yaml
WORKLOAD_CONTEXT=default

VAULT_ADDR=https://vault.example.internal:8200
VAULT_TOKEN_FILE=/secure/vault/root-token.txt
VAULT_AUTH_MOUNT_PATH=kubernetes
VAULT_KV_MOUNT=kv

VAULT_K8S_NAMESPACE=vault
VAULT_TOKEN_REVIEWER_SERVICE_ACCOUNT=vault-token-reviewer
VAULT_TOKEN_REVIEWER_BINDING_NAME=vault-token-reviewer

VAULT_ROLE_AUDIENCE=vault
VAULT_ROLE_TTL=1h
VAULT_ROLE_MAX_TTL=24h

VAULT_SECRETS_DIR=/secure/vault-secrets
